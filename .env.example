# Shared secret used to authenticate POSTs from the Zapier "SweepBright"
# Zaps to /api/webhooks/sweepbright-zapier (header X-Zapier-Secret).
# Generate with `openssl rand -hex 32`. Rotate annually or whenever the
# value has been exposed (chat, screenshot, browser inspect, etc.).
SWEEPBRIGHT_ZAPIER_WEBHOOK_SECRET=
# Google Tag Manager. Set ONLY on the production environment (e.g. GTM-WCCJQJN2).
# Leave empty on local / preview to avoid polluting analytics with non-prod traffic.
NEXT_PUBLIC_GTM_ID=
